# ============================================
# SUPABASE
# ============================================
# Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Also expose the anon key + URL to the browser (index.html reads these two)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ============================================
# OPENROUTER (powers every AI model — single key)
# ============================================
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx
# Optional but recommended by OpenRouter for analytics/rankings
OPENROUTER_SITE_URL=https://sharekit.in
OPENROUTER_SITE_NAME=ShareKit

# ============================================
# RAZORPAY
# ============================================
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
RAZORPAY_PLAN_ID=plan_xxxxxxxxxxxx
# Exposed to the browser so Razorpay Checkout can open (public key only, safe to expose)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx

# ============================================
# FIREBASE CLOUD MESSAGING (push notifications)
# ============================================
# From Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=sharekit-xxxxx
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@sharekit-xxxxx.iam.gserviceaccount.com
# Paste the private_key value from the JSON file, keep the \n escape sequences as-is
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nxxxxx\n-----END PRIVATE KEY-----\n"
# From Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your-vapid-key
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-web-api-key
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# ============================================
# CRON SECURITY
# ============================================
# Any random 16+ character string. Vercel sends this automatically as
# "Authorization: Bearer <value>" when it triggers /api/cron.
CRON_SECRET=change-this-to-a-random-string
